# ============================================================================
# Office Face-Recognition Attendance System — configuration
# Copy to `.env` and fill in real secrets. NEVER commit the real .env.
# ============================================================================

# --- Application Postgres (separate from CompreFace's internal Postgres) ---
POSTGRES_USER=attendance
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=attendance
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://attendance:change-me-strong-password@postgres:5432/attendance

# --- Redis (cooldown / dedup keys, WS pub-sub) ---
REDIS_URL=redis://redis:6379/0

# --- Auth ---
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
# Bootstrap admin created on first startup if no admin exists
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=change-me-admin-password

# --- CompreFace integration ---
# The FE gateway URL as seen from the api container (compose network) or host.
COMPREFACE_URL=http://compreface-ui:80
# API key of a CompreFace "Recognition" service. Created once in the CompreFace
# UI (http://localhost:8900) after first boot; paste it here.
COMPREFACE_RECOGNITION_API_KEY=

# --- Liveness service ---
LIVENESS_URL=http://liveness:8902
# Minimum liveness score [0..1] to accept a frame as a real, live face.
LIVENESS_THRESHOLD=0.85

# --- Business rules (all runtime-adjustable via admin settings later) ---
# Recognition confidence [0..1]; below this a match is treated as unrecognized.
RECOGNITION_CONFIDENCE_THRESHOLD=0.90
# Per-person cooldown seconds on a given device to avoid double triggers.
COOLDOWN_SECONDS=30
# Hour (0-23) that defines the workday cutoff for auto-flagging open sessions.
WORKDAY_CUTOFF_HOUR=23
# Retention window for captured audit images before auto-deletion.
IMAGE_RETENTION_DAYS=14

# --- Storage ---
# Where captured audit images are written (mounted volume in compose).
DATA_DIR=/data
# Optional Fernet key to encrypt captured images at rest (base64, 32 bytes).
IMAGE_ENCRYPTION_KEY=

# --- Networking / CORS ---
DASHBOARD_ORIGIN=http://localhost:5173
API_PORT=8901
